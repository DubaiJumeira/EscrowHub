# EscrowHub single-VPS deposit-ready example
APP_ENV=production
TELEGRAM_BOT_TOKEN=replace-me
ADMIN_USER_IDS=123456789

# SQLite (DATABASE_URL is accepted as an alias)
DATABASE_URL=/opt/escrowhub/escrowhub.db

# Required in production for encrypted wallet route storage
ENCRYPTION_KEY=replace-with-a-long-random-secret

# Self-hosted deposit issuance
ADDRESS_PROVIDER=local_hd
HD_WALLET_SEED_HEX=replace-with-64-or-more-hex-bytes

# Watchers
BTC_WATCHER_ENABLED=true
ETH_WATCHER_ENABLED=true
WATCHER_POLL_INTERVAL_SECONDS=30

# Chain endpoints
BTC_RPC_URL=https://blockstream.info/api
ETH_RPC_URL=https://eth.llamarpc.com
ETH_NETWORK=ethereum

# SOL watcher remains disabled until first-enable bootstrap is prepared.
SOL_WATCHER_ENABLED=false
SOL_RPC_URL=
SOL_CONFIRMATIONS_REQUIRED=32
SOL_MAX_SLOTS_PER_RUN=64
SOL_START_SLOT=0

# Optional: enable ERC-20 USDT deposit detection
USDT_ERC20_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7

# Keep withdrawals off unless you have a real external withdrawal provider
WITHDRAWALS_ENABLED=false


# === PLATFORM FEES ===
DEPOSIT_PLATFORM_FEE_PERCENT=1
WITHDRAWAL_PLATFORM_FEE_PERCENT=1
ESCROW_PLATFORM_FEE_PERCENT=3
PROVIDER_FEE_ENABLED=false

# === MULTI-ASSET WATCHERS ===
LTC_WATCHER_ENABLED=true
LTC_RPC_URL=https://litecoinspace.org/api
ETH_WATCHER_ENABLED=true
# ETH_RPC_URL=https://your-ethereum-rpc.example
USDT_ERC20_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7
